# MongoDB connection string. For deployment (e.g. Render), this must be a
# reachable cloud database (MongoDB Atlas free tier works) - "localhost"
# only works for local development.
MONGODB_URI=mongodb://localhost:27017/finsight

# Secrets used to sign JWTs. Use long, random, different values in
# production - do not reuse the values from local development.
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

PORT=5000
NODE_ENV=development

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
# Optional: override the model if the default is ever deprecated again.
# GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of allowed frontend origins.
CORS_ORIGIN=http://localhost:5173
